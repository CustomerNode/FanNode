#!/usr/bin/env bash
# fannode — userland fan-curve daemon for Dell desktops
# https://github.com/CustomerNode/FanNode

set -euo pipefail

VERSION="0.2.0"
CONFIG_FILE="${FANNODE_CONFIG:-/etc/fannode.conf}"
STATE_DIR="/run/fannode"
STATUS_FILE="${STATE_DIR}/status.json"
LOG_TAG="fannode"

# Defaults — overridden by /etc/fannode.conf
INTERVAL=3
CORETEMP_HWMON=""
DELL_SMM_HWMON=""

# Multi-fan support. MANAGED_FANS is a list of logical fan names; each name
# maps to a PWM and tach file via FAN_PWM_FILE / FAN_TACH_FILE.
# Defaults populated in discover_hwmon() once we find dell_smm.
declare -a MANAGED_FANS=()
declare -A FAN_PWM_FILE
declare -A FAN_TACH_FILE
declare -A FAN_DESC

# Curve (shared across all managed fans for now)
CURVE_NORMAL_MAX_TEMP=70
CURVE_NORMAL_PWM=80
CURVE_WARM_MAX_TEMP=85
CURVE_WARM_PWM=180
CURVE_HOT_MAX_TEMP=95
CURVE_HOT_PWM=240
CURVE_CRITICAL_PWM=255
HYSTERESIS_DROP=3
CRITICAL_TEMP=95
SUSTAINED_HOT_SECS=120

# Runtime state
CURRENT_ZONE="normal"
declare -A LAST_PWM
declare -A LAST_PWM_READBACK
declare -A BIOS_RECLAIM_COUNT
HOT_SINCE=0
DAEMON_START=$(date +%s)

# Backward-compat config keys: if PWM_FILE / TACH_FILE are set, treat them as
# the cpu fan path overrides. Pre-0.2 fannode.conf files keep working.
PWM_FILE=""
TACH_FILE=""

log()  { logger -t "$LOG_TAG" -- "$*"; printf '[%s] %s\n' "$(date -Iseconds)" "$*" >&2; }
die()  { log "FATAL: $*"; exit 1; }

load_config() {
    if [[ -f "$CONFIG_FILE" ]]; then
        # shellcheck source=/dev/null
        source "$CONFIG_FILE"
    fi
}

discover_hwmon() {
    local h name
    for h in /sys/class/hwmon/hwmon*; do
        [[ -d "$h" ]] || continue
        name=$(cat "$h/name" 2>/dev/null) || continue
        case "$name" in
            coretemp) CORETEMP_HWMON="$h" ;;
            dell_smm) DELL_SMM_HWMON="$h" ;;
        esac
    done

    # Populate per-fan paths from dell_smm (only if not already set in config).
    if [[ -n "$DELL_SMM_HWMON" ]]; then
        : "${FAN_PWM_FILE[cpu]:=${DELL_SMM_HWMON}/pwm1}"
        : "${FAN_TACH_FILE[cpu]:=${DELL_SMM_HWMON}/fan1_input}"
        : "${FAN_DESC[cpu]:=Processor Fan}"
        : "${FAN_PWM_FILE[motherboard]:=${DELL_SMM_HWMON}/pwm2}"
        : "${FAN_TACH_FILE[motherboard]:=${DELL_SMM_HWMON}/fan2_input}"
        : "${FAN_DESC[motherboard]:=Motherboard Fan}"
        : "${FAN_PWM_FILE[psu]:=${DELL_SMM_HWMON}/pwm3}"
        : "${FAN_TACH_FILE[psu]:=${DELL_SMM_HWMON}/fan3_input}"
        : "${FAN_DESC[psu]:=Power Supply Fan}"
    fi

    # Backward-compat: pre-0.2 PWM_FILE / TACH_FILE override the cpu entry.
    [[ -n "$PWM_FILE"  ]] && FAN_PWM_FILE[cpu]="$PWM_FILE"
    [[ -n "$TACH_FILE" ]] && FAN_TACH_FILE[cpu]="$TACH_FILE"

    # If user didn't configure MANAGED_FANS, default to managing cpu+motherboard.
    # Skip psu by default — its PWM is driven by the PSU itself; user can opt in.
    if (( ${#MANAGED_FANS[@]} == 0 )); then
        MANAGED_FANS=(cpu motherboard)
    fi
}

validate_managed_fans() {
    local fan pwm_file tach_file kept=()
    for fan in "${MANAGED_FANS[@]}"; do
        pwm_file=${FAN_PWM_FILE[$fan]:-}
        tach_file=${FAN_TACH_FILE[$fan]:-}

        if [[ -z "$pwm_file" || ! -e "$pwm_file" ]]; then
            log "WARN: dropping '$fan' — PWM file '${pwm_file:-?}' not found"
            continue
        fi
        if [[ ! -w "$pwm_file" ]]; then
            log "WARN: dropping '$fan' — PWM file '$pwm_file' not writable"
            continue
        fi
        if [[ -z "$tach_file" || ! -e "$tach_file" ]]; then
            log "WARN: '$fan' has no readable tach at '${tach_file:-?}' — RPM will report 0"
        fi

        LAST_PWM[$fan]=-1
        LAST_PWM_READBACK[$fan]=-1
        BIOS_RECLAIM_COUNT[$fan]=0
        kept+=("$fan")
    done
    MANAGED_FANS=("${kept[@]}")
    (( ${#MANAGED_FANS[@]} > 0 )) || die "No fans available for management."
}

read_max_core_temp() {
    local max=0 t f
    for f in "$CORETEMP_HWMON"/temp*_input; do
        [[ -f "$f" ]] || continue
        t=$(<"$f")
        t=$(( t / 1000 ))
        (( t > max )) && max=$t
    done
    echo "$max"
}

# Emits inner JSON fields: "core0":47,"core1":50
read_core_temps_json() {
    local first=1 f label_file label t
    for f in "$CORETEMP_HWMON"/temp*_input; do
        [[ -f "$f" ]] || continue
        label_file="${f%_input}_label"
        label="core?"
        if [[ -f "$label_file" ]]; then
            label=$(<"$label_file")
            label="${label// /}"
            label="${label,,}"
        fi
        t=$(<"$f")
        t=$(( t / 1000 ))
        (( first )) && first=0 || printf ','
        printf '"%s":%d' "$label" "$t"
    done
}

zone_for() {
    local t=$1 cur=$CURRENT_ZONE
    case "$cur" in
        normal)
            (( t > CURVE_NORMAL_MAX_TEMP )) && { echo warm; return; }
            ;;
        warm)
            (( t > CURVE_WARM_MAX_TEMP )) && { echo hot; return; }
            (( t < CURVE_NORMAL_MAX_TEMP - HYSTERESIS_DROP )) && { echo normal; return; }
            ;;
        hot)
            (( t >= CRITICAL_TEMP )) && { echo critical; return; }
            (( t < CURVE_WARM_MAX_TEMP - HYSTERESIS_DROP )) && { echo warm; return; }
            ;;
        critical)
            (( t < CURVE_HOT_MAX_TEMP - HYSTERESIS_DROP )) && { echo hot; return; }
            ;;
    esac
    echo "$cur"
}

pwm_for_zone() {
    case "$1" in
        normal)   echo "$CURVE_NORMAL_PWM" ;;
        warm)     echo "$CURVE_WARM_PWM" ;;
        hot)      echo "$CURVE_HOT_PWM" ;;
        critical) echo "$CURVE_CRITICAL_PWM" ;;
        *)        echo "$CURVE_NORMAL_PWM" ;;
    esac
}

apply_pwm() {
    local fan=$1 pwm=$2 readback=-1 drop last
    local pwm_file=${FAN_PWM_FILE[$fan]}
    [[ -w "$pwm_file" ]] || { log "PWM not writable: $pwm_file"; return 1; }
    last=${LAST_PWM[$fan]}

    # Detect BIOS reclaim. Read the current value before writing — that's what
    # the BIOS may have done to last cycle's assert. We only flag *downward*
    # divergence (which means insufficient cooling); upward clamps are safer.
    # Threshold: drop > 24 PWM AND > 15% of what we wrote.
    if (( last > 64 )) && [[ -r "$pwm_file" ]]; then
        readback=$(<"$pwm_file")
        drop=$(( last - readback ))
        if (( drop > 24 )) && (( readback * 100 < last * 85 )); then
            BIOS_RECLAIM_COUNT[$fan]=$(( ${BIOS_RECLAIM_COUNT[$fan]} + 1 ))
        fi
    elif [[ -r "$pwm_file" ]]; then
        readback=$(<"$pwm_file")
    fi
    echo "$pwm" > "$pwm_file"
    LAST_PWM[$fan]=$pwm
    LAST_PWM_READBACK[$fan]=$readback
}

determine_health() {
    local max_t=$1 pwm=$2 now total_reclaim=0 fan
    now=$(date +%s)
    if (( max_t >= CRITICAL_TEMP && pwm >= 250 )); then
        echo thermal_overrun
        return
    fi
    if (( max_t >= CURVE_HOT_MAX_TEMP )); then
        (( HOT_SINCE == 0 )) && HOT_SINCE=$now
        if (( now - HOT_SINCE >= SUSTAINED_HOT_SECS )); then
            echo sustained_hot
            return
        fi
    else
        HOT_SINCE=0
    fi
    for fan in "${MANAGED_FANS[@]}"; do
        total_reclaim=$(( total_reclaim + ${BIOS_RECLAIM_COUNT[$fan]} ))
    done
    if (( total_reclaim >= 5 )); then
        echo bios_reclaim
        return
    fi
    echo ok
}

# Render the "fans" object as inner JSON entries:
# "cpu":{"pwm":80,"pwm_readback":128,"rpm":2115,"bios_reclaim_count":0},...
render_fans_json() {
    local first=1 fan rpm tach
    for fan in "${MANAGED_FANS[@]}"; do
        rpm=0
        tach=${FAN_TACH_FILE[$fan]:-}
        [[ -n "$tach" && -r "$tach" ]] && rpm=$(<"$tach")
        (( first )) && first=0 || printf ','
        printf '"%s":{"pwm":%d,"pwm_readback":%d,"rpm":%d,"bios_reclaim_count":%d}' \
               "$fan" \
               "${LAST_PWM[$fan]}" \
               "${LAST_PWM_READBACK[$fan]}" \
               "$rpm" \
               "${BIOS_RECLAIM_COUNT[$fan]}"
    done
}

write_status() {
    local max_t=$1 zone=$2 pwm=$3 health=$4
    local now uptime cores fans_json tmp
    local primary primary_rpm primary_pwm primary_readback primary_reclaim primary_tach

    now=$(date -Iseconds)
    uptime=$(( $(date +%s) - DAEMON_START ))
    cores=$(read_core_temps_json)
    fans_json=$(render_fans_json)

    # Legacy top-level fields = primary fan (= first in MANAGED_FANS, normally cpu)
    primary=${MANAGED_FANS[0]}
    primary_pwm=${LAST_PWM[$primary]}
    primary_readback=${LAST_PWM_READBACK[$primary]}
    primary_reclaim=${BIOS_RECLAIM_COUNT[$primary]}
    primary_rpm=0
    primary_tach=${FAN_TACH_FILE[$primary]:-}
    [[ -n "$primary_tach" && -r "$primary_tach" ]] && primary_rpm=$(<"$primary_tach")

    tmp="${STATUS_FILE}.tmp"
    cat > "$tmp" <<EOF
{
  "active": true,
  "health": "$health",
  "core_temps": {$cores},
  "max_core_temp": $max_t,
  "zone": "$zone",
  "pwm": $primary_pwm,
  "pwm_readback": $primary_readback,
  "fan_rpm": $primary_rpm,
  "bios_reclaim_count": $primary_reclaim,
  "fans": {$fans_json},
  "primary_fan": "$primary",
  "uptime_seconds": $uptime,
  "last_update": "$now",
  "version": "$VERSION"
}
EOF
    mv -f "$tmp" "$STATUS_FILE"
}

cleanup() {
    log "Stopping. Fan control will return to BIOS within a few minutes."
    rm -f "$STATUS_FILE"
    exit 0
}

cmd_start() {
    load_config
    discover_hwmon
    [[ -d "$CORETEMP_HWMON" ]] || die "coretemp hwmon not found (is the coretemp module loaded?)"
    validate_managed_fans
    mkdir -p "$STATE_DIR"
    chmod 0755 "$STATE_DIR"
    trap cleanup TERM INT HUP

    log "FanNode $VERSION starting (interval=${INTERVAL}s, fans=${MANAGED_FANS[*]})"

    local t zone pwm health fan
    while true; do
        if ! t=$(read_max_core_temp) || (( t == 0 )); then
            health=sensor_error
            zone=$CURRENT_ZONE
            pwm=${LAST_PWM[${MANAGED_FANS[0]}]}
            (( pwm < 0 )) && pwm=$CURVE_HOT_PWM   # fail safe to high cooling
        else
            zone=$(zone_for "$t")
            CURRENT_ZONE=$zone
            pwm=$(pwm_for_zone "$zone")
            for fan in "${MANAGED_FANS[@]}"; do
                apply_pwm "$fan" "$pwm" || health=sensor_error
            done
            health=$(determine_health "$t" "$pwm")
        fi
        write_status "$t" "$zone" "$pwm" "$health"
        sleep "$INTERVAL"
    done
}

cmd_status() {
    if [[ ! -f "$STATUS_FILE" ]]; then
        echo "FanNode is not running." >&2
        echo "Start with: sudo systemctl start fannode" >&2
        exit 1
    fi
    if [[ "${1:-}" == "--json" ]]; then
        cat "$STATUS_FILE"
        return
    fi
    local zone max_t health uptime pwm pwm_pct
    zone=$(grep -oP    '"zone":\s*"\K[^"]+'             "$STATUS_FILE")
    max_t=$(grep -oP   '"max_core_temp":\s*\K[0-9]+'    "$STATUS_FILE")
    health=$(grep -oP  '"health":\s*"\K[^"]+'           "$STATUS_FILE")
    uptime=$(grep -oP  '"uptime_seconds":\s*\K[0-9]+'   "$STATUS_FILE")
    pwm=$(grep -oP     '"pwm":\s*\K[0-9]+'              "$STATUS_FILE" | head -1)
    pwm_pct=$(( pwm * 100 / 255 ))

    echo "FanNode — active"
    echo "Hottest core: ${max_t}°C   Curve zone: ${zone}   Health: ${health}"
    echo "Daemon: running for ${uptime}s"
    echo

    if command -v jq >/dev/null 2>&1; then
        printf '%-14s %-6s %-13s %-5s %s\n' "FAN" "PWM" "READBACK" "RPM" "RECLAIMS"
        local name fpwm rb rpm reclaim fpwm_pct clamp
        while IFS=$'\t' read -r name fpwm rb rpm reclaim; do
            fpwm_pct=$(( fpwm * 100 / 255 ))
            clamp=""
            if [[ -n "$rb" && "$rb" -ge 0 && "$rb" != "$fpwm" ]]; then
                clamp=" (clamped to ${rb})"
            fi
            printf '%-14s %-6s %-13s %-5s %s\n' \
                "$name" "${fpwm_pct}%" "$rb" "$rpm" "$reclaim"
            [[ -n "$clamp" ]] && printf '%-14s %s\n' "" "$clamp"
        done < <(jq -r '.fans | to_entries[] |
                        "\(.key)\t\(.value.pwm)\t\(.value.pwm_readback)\t\(.value.rpm)\t\(.value.bios_reclaim_count)"' \
                    "$STATUS_FILE" 2>/dev/null)
    else
        # Fallback: just primary fan from legacy fields. The status JSON
        # contains bios_reclaim_count both at top-level and once per fan,
        # so head -1 picks the legacy (top-level) value.
        local rpm reclaim
        rpm=$(grep -oP     '"fan_rpm":\s*\K[0-9]+'           "$STATUS_FILE" | head -1)
        reclaim=$(grep -oP '"bios_reclaim_count":\s*\K[0-9]+' "$STATUS_FILE" | head -1)
        echo "Primary fan: ${rpm} RPM (${pwm_pct}% PWM)   BIOS reclaim events: ${reclaim}"
        echo "(install 'jq' for per-fan breakdown)"
    fi
}

cmd_tail() { exec journalctl -fu fannode "$@"; }

cmd_doctor() {
    local ok=true product fan
    say() {
        printf '  [%s] %s\n' "$1" "$2"
        if [[ "$1" == FAIL ]]; then ok=false; fi
        return 0
    }

    echo "FanNode doctor (v$VERSION):"

    product=$(cat /sys/devices/virtual/dmi/id/product_name 2>/dev/null || echo unknown)
    if [[ "$product" == *"Studio XPS 9100"* ]]; then
        say OK   "Hardware: $product (tested)"
    else
        say WARN "Hardware: $product (untested — open a hardware report)"
    fi

    if grep -q '^dell_smm_hwmon ' /proc/modules; then
        say OK   "dell_smm_hwmon loaded"
    else
        say FAIL "dell_smm_hwmon not loaded"
    fi
    if grep -q '^coretemp ' /proc/modules; then
        say OK   "coretemp loaded"
    else
        say FAIL "coretemp not loaded"
    fi

    load_config
    discover_hwmon
    [[ -d "$CORETEMP_HWMON" ]] && say OK   "coretemp hwmon: $CORETEMP_HWMON" \
                               || say FAIL "coretemp hwmon not found"

    echo "  Managed fans (from config or default):"
    for fan in "${MANAGED_FANS[@]}"; do
        local pwm_file=${FAN_PWM_FILE[$fan]:-}
        local tach_file=${FAN_TACH_FILE[$fan]:-}
        local desc=${FAN_DESC[$fan]:-$fan}
        if [[ -e "$pwm_file" && -w "$pwm_file" ]]; then
            say OK   "$fan ($desc): pwm=$pwm_file (writable), tach=$tach_file"
        elif [[ -e "$pwm_file" ]]; then
            say FAIL "$fan ($desc): pwm=$pwm_file exists but is NOT writable (run as root?)"
        else
            say FAIL "$fan ($desc): pwm file '$pwm_file' missing"
        fi
    done

    if systemctl is-active --quiet fannode 2>/dev/null; then
        say OK   "fannode.service is active"
    else
        say WARN "fannode.service is not active (sudo systemctl start fannode)"
    fi

    $ok || exit 1
}

cmd_install()   { exec /usr/local/share/fannode/install.sh   "$@"; }
cmd_uninstall() { exec /usr/local/share/fannode/uninstall.sh "$@"; }

usage() {
    cat <<EOF
FanNode $VERSION — userland fan-curve daemon for Dell desktops

Usage: fannode <command>

Commands:
  start            Run the daemon (foreground; used by systemd)
  status [--json]  Show current state
  tail             Follow journal output
  doctor           Check hardware, modules, permissions
  install          (Re-)install FanNode
  uninstall        Remove FanNode and hand fan control back to BIOS

Docs: https://github.com/CustomerNode/FanNode
EOF
}

main() {
    local cmd=${1:-}
    [[ -z "$cmd" ]] && { usage; exit 1; }
    shift || true
    case "$cmd" in
        start)              cmd_start     "$@" ;;
        status)             cmd_status    "$@" ;;
        tail)               cmd_tail      "$@" ;;
        doctor)             cmd_doctor    "$@" ;;
        install)            cmd_install   "$@" ;;
        uninstall)          cmd_uninstall "$@" ;;
        -h|--help|help)     usage ;;
        -V|--version)       echo "fannode $VERSION" ;;
        *)                  usage; exit 1 ;;
    esac
}

main "$@"
